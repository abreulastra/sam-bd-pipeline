# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# SAM.gov API key — get one at https://sam.gov/profile/details
SAM_API_KEY=your_sam_api_key_here

# Full URL of your Google Spreadsheet
SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id_here

# Google Service Account credentials as a single-line JSON string
# Alternative: if running locally, you can use the file path approach below
# and set this by running: export GOOGLE_SERVICE_ACCOUNT_JSON=$(cat secrets/service-account.json)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: filter opportunities by keyword in the title
# KEYWORDS=cybersecurity
