# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# SAM.gov API key — get one at https://sam.gov/profile/details
SAM_API_KEY=your_sam_api_key_here

# Full URL of your Google Spreadsheet
SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id_here

# Google Service Account credentials as a single-line JSON string
# Alternative: if running locally, you can use the file path approach below
# and set this by running: export GOOGLE_SERVICE_ACCOUNT_JSON=$(cat secrets/service-account.json)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: filter opportunities by keyword in the title
# KEYWORDS=cybersecurity

# ── Email Pipeline (Gmail → Pipeline tab) ────────────────────────────────────
# OAuth2 credentials for rabreu@c-230.com Gmail account
# Generate via Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_ACCOUNT_EMAIL=rabreu@c-230.com

# Sender address DevelopmentAid alerts are forwarded from.
# Without this, the Gmail search falls back to a broad body-text match
# that can pick up unrelated threads mentioning "DevelopmentAid".
DEVELOPMENTAID_SENDER=pipeline@c-230.com

# Google Sheet ID (the part between /d/ and /edit in the sheet URL)
GOOGLE_SHEET_ID=1AszPkKxACogpOkcHrCGzHGXdN4cDzu1-T75wsVb-Mlg
